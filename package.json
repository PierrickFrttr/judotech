{
  "name": "judotech",
  "version": "1.0.0",
  "description": "Application de révision UV technique pour la ceinture noire de judo",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "cross-env BUILD_TARGET=electron vite build && electron-builder",
    "build:win": "cross-env BUILD_TARGET=electron vite build && electron-builder --win",
    "build:web": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx"
  },
  "build": {
    "appId": "fr.judotech.app",
    "productName": "JudoTech",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JudoTech"
    },
    "directories": {
      "output": "dist-build",
      "buildResources": "build"
    }
  },
  "dependencies": {
    "electron-store": "^7.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
